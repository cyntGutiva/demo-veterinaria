---
import LocationIcon from "./icons/LocationIcon.astro";
import PhoneIcon from "./icons/PhoneIcon.astro";
import WatchIcon from "./icons/WatchIcon.astro";
---

<section
  id="contacto"
  class="m-6 lg:m-10 bg-slate-950 text-white rounded-[3rem] p-10 lg:p-20 overflow-hidden relative"
>
  <div
    class="absolute top-0 right-0 w-96 h-96 bg-primary/20 blur-[120px] rounded-full -mr-48 -mt-48"
  >
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 relative z-10">
    <div>
      <h2 class="text-4xl lg:text-5xl font-extrabold mb-8 tracking-tight">
        Agenda tu visita hoy mismo.
      </h2>
      <div class="space-y-6 text-slate-400 font-semibold">
        <div class="flex items-center gap-4">
          <div
            class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center text-white"
          >
            <nav class="flex items-center gap-2">
              <LocationIcon class="w-6 h-6 md:w-8 md:h-8" />
            </nav>
          </div>
          Calle Mascotas 123, Ciudad Central
        </div>
        <div class="flex items-center gap-4">
          <div
            class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center text-white"
          >
            <nav class="flex items-center gap-2">
              <PhoneIcon class="w-6 h-6 md:w-7 md:h-7" />
            </nav>
          </div>
          +56 9 8888 7777
        </div>
        <div class="flex items-center gap-4">
          <div
            class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center text-white"
          >
            <nav class="flex items-center gap-2">
              <WatchIcon class="w-6 h-6 md:w-8 md:h-8" />
            </nav>
          </div>
          Lun - Sab: 09:00 - 20:00
        </div>
      </div>
    </div>
    <div
      class="h-[400px] bg-gray-900 rounded-3xl overflow-hidden border border-white/10 shadow-2xl"
    >
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d26667.61919958752!2d-70.71816538709223!3d-33.33326564377249!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9662c753c9ed8c5b%3A0xffe0cabc56033210!2sEaston%20Outlet%20Mall!5e0!3m2!1ses!2scl!4v1773958249924!5m2!1ses!2scl"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
  <footer
    class="mt-20 pt-8 border-t border-white/5 text-center text-xs text-slate-600 font-bold uppercase tracking-widest"
  >
    HealthyPet Clinical Center 2026
  </footer>
</section>
