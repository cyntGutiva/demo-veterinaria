---
import LocationIcon from "./icons/LocationIcon.astro";
import PhoneIcon from "./icons/PhoneIcon.astro";
import WatchIcon from "./icons/WatchIcon.astro";
---

<section id="contacto" class="m-6 lg:m-10 bg-slate-950 text-white rounded-[3rem] p-10 lg:p-20 overflow-hidden relative">
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary/20 blur-[120px] rounded-full -mr-48 -mt-48"></div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 relative z-10">
        <div>
            <h2 class="text-4xl lg:text-5xl font-extrabold mb-8 tracking-tight">Agenda tu visita hoy mismo.</h2>
            <div class="space-y-6 text-slate-400 font-semibold">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center text-white">
                        <nav class="flex items-center gap-2">
                            <LocationIcon class="w-6 h-6 md:w-8 md:h-8" />
                        </nav>
                    </div>
                        Calle Mascotas 123, Ciudad Central
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center text-white">
                    <nav class="flex items-center gap-2">
                            <PhoneIcon class="w-6 h-6 md:w-7 md:h-7" />
                        </nav>
                    </div>
                    +56 9 8888 7777
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center text-white">
                        <nav class="flex items-center gap-2">
                            <WatchIcon class="w-6 h-6 md:w-8 md:h-8" />
                        </nav>
                    </div>
                        Lun - Sab: 09:00 - 20:00
                </div>
            </div>
        </div>
        <div class="bg-white/5 p-8 rounded-[2rem] border border-white/10">
            <h3 class="text-xl font-bold mb-6">WhatsApp Express</h3>
            <a href="#" class="block w-full py-4 bg-[#25D366] text-white text-center rounded-2xl font-extrabold hover:scale-[1.02] transition-transform">
                ENVIAR MENSAJE
            </a>
            <p class="text-center text-slate-500 text-xs mt-6 uppercase tracking-widest">Respuesta en menos de 10 min</p>
        </div>
    </div>
    <footer class="mt-20 pt-8 border-t border-white/5 text-center text-xs text-slate-600 font-bold uppercase tracking-widest">
        HealthyPet Clinical Center 2026
    </footer>
</section>