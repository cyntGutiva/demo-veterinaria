<section id="galeria" class="py-20 px-[5%]">
    <h2 class="text-3xl font-extrabold mb-12 text-center">Conoce nuestras instalaciones</h2>
    
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {[
            "https://images.unsplash.com/photo-1596272875729-ed2ff7d6d9c5",
            "https://i.pinimg.com/736x/e2/89/7a/e2897a122e44bed98b74019328ac9734.jpg",
            "https://images.unsplash.com/photo-1629909613654-28e377c37b09",
            "https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba"
        ].map(img => (
            <div 
                class="gallery-item h-72 rounded-[2rem] overflow-hidden border-4 border-white shadow-xl group cursor-pointer relative"
                data-full={`${img}?auto=format&fit=crop&w=1200&q=90`}
            >
                <img 
                    src={`${img}?auto=format&fit=crop&w=600&q=60`} 
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
                    alt="Instalaciones HealthyPet"
                />
                <div class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                    <span class="bg-white text-primary p-3 rounded-full shadow-lg text-xl">🔍</span>
                </div>
            </div>
        ))}
    </div>

    <div 
        id="lightbox" 
        class="fixed inset-0 z-[2000] bg-slate-950/90 backdrop-blur-md flex items-center justify-center opacity-0 pointer-events-none transition-all duration-500 ease-in-out p-4"
    >
        <button id="close-btn" class="absolute top-6 right-6 text-white p-2 hover:scale-110 transition-transform">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
        
        <img 
            id="lightbox-img" 
            src="" 
            class="max-w-full max-h-[85vh] rounded-[2rem] shadow-2xl border-4 border-white/10 transform scale-90 transition-transform duration-500 ease-out"
            alt="Vista ampliada"
        />
    </div>
</section>

<script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const closeBtn = document.getElementById('close-btn');
    const items = document.querySelectorAll('.gallery-item');

    const openLightbox = (url: string) => {
        if (!lightbox || !lightboxImg) return;
        
        lightboxImg.src = url;
        // Quitar pointer-events-none y poner opacity-100
        lightbox.classList.remove('opacity-0', 'pointer-events-none');
        lightbox.classList.add('opacity-100');
        // Efecto de escala en la imagen
        setTimeout(() => {
            lightboxImg.classList.remove('scale-90');
            lightboxImg.classList.add('scale-100');
        }, 10);
    };

    const closeLightbox = () => {
        if (!lightbox || !lightboxImg) return;
        
        lightbox.classList.add('opacity-0', 'pointer-events-none');
        lightbox.classList.remove('opacity-100');
        lightboxImg.classList.remove('scale-100');
        lightboxImg.classList.add('scale-90');
    };

    // Eventos
    items.forEach(item => {
        item.addEventListener('click', () => {
            const fullUrl = item.getAttribute('data-full');
            if (fullUrl) openLightbox(fullUrl);
        });
    });

    closeBtn?.addEventListener('click', closeLightbox);
    
    // Cerrar al hacer click en el fondo negro
    lightbox?.addEventListener('click', (e) => {
        if (e.target === lightbox) closeLightbox();
    });

    // Cerrar con Escape
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
    });
</script>