<section id="galeria" class="section-padding">
    <h2 class="text-3xl font-extrabold mb-12 text-center">Conoce nuestras instalaciones</h2>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {[
            "https://images.unsplash.com/photo-1596272875729-ed2ff7d6d9c5",
            "https://i.pinimg.com/736x/e2/89/7a/e2897a122e44bed98b74019328ac9734.jpg",
            "https://images.unsplash.com/photo-1629909613654-28e377c37b09",
            "https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba"
        ].map(img => (
            <div class="h-72 rounded-[2rem] overflow-hidden border-4 border-white shadow-card group cursor-pointer relative">
                <img src={`${img}?auto=format&fit=crop&w=600&q=60`} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                <div class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                    <span class="bg-white text-primary p-3 rounded-full shadow-lg">✨</span>
                </div>
            </div>
        ))}
    </div>
</section>