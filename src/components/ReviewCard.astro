---
interface Props {
  name: string;
  date: string;
  text: string;
  avatar: string;
}
const { name, date, text, avatar } = Astro.props;
---
<div class="bg-white p-8 rounded-[2.5rem] border border-blue-50 shadow-sm hover:shadow-xl transition-all duration-500 group">
  <div class="flex items-center gap-4 mb-6">
    <img src={avatar} alt={name} class="w-14 h-14 rounded-full border-2 border-primary/10 object-cover" />
    <div>
      <h4 class="font-extrabold text-slate-900 leading-tight">{name}</h4>
      <p class="text-xs text-slate-400 font-bold uppercase tracking-wider">{date}</p>
    </div>
    <div class="ml-auto text-yellow-400 flex gap-0.5">
      {[1, 2, 3, 4, 5].map(() => (
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
      ))}
    </div>
  </div>
  <p class="text-slate-600 leading-relaxed italic">"{text}"</p>
</div>